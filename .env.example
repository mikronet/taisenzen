# Servidor
PORT=3000
# Cambiar a 'production' en producción
NODE_ENV=development

# Contraseña del panel de administración (OBLIGATORIO — usar una contraseña fuerte)
ADMIN_PASSWORD=cambiar_por_una_contrasena_fuerte

# Orígenes CORS permitidos en producción (separados por coma, sin espacios)
# Ejemplo: ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com
ALLOWED_ORIGINS=

# Email de contacto (opcional — si no se configura, los mensajes solo se guardan en DB)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# Dirección de destino de los mensajes de contacto
CONTACT_TO=
