# Servidor
PORT=3000
# Cambiar a 'production' en producción
NODE_ENV=development

# Contraseña del panel de administración (OBLIGATORIO — usar una contraseña fuerte)
ADMIN_PASSWORD=cambiar_por_una_contrasena_fuerte

# Dominio principal en producción — acepta el dominio raíz y TODOS sus subdominios
# Ejemplo: taisen.es → acepta taisen.es, www.taisen.es, admin.taisen.es, etc.
ALLOWED_DOMAIN=taisen.es

# Orígenes adicionales permitidos (opcional, separados por coma)
# Solo necesario si hay dominios externos que deban acceder a la API
ALLOWED_ORIGINS=

# Email de contacto (opcional — si no se configura, los mensajes solo se guardan en DB)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# Dirección de destino de los mensajes de contacto
CONTACT_TO=
